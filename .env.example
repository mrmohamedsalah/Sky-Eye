# ==========================
# Sky Eye Environment Example
# Copy this file to .env and fill real values locally.
# Do NOT commit .env.
# ==========================

# OpenSky API
OPENSKY_USERNAME=your_opensky_username
OPENSKY_PASSWORD=your_opensky_password

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka1:19092
KAFKA_TOPIC=opensky

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=opensky-data
MINIO_PREFIX=opensky/Streaming/

# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change_me
CLICKHOUSE_DATABASE=opensky

# Snowflake
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=AIRLINES
SNOWFLAKE_SCHEMA=GOLD_ML

# AWS
AWS_REGION=us-east-1
S3_BUCKET=your_s3_bucket_name
SNOWFLAKE_STORAGE_INTEGRATION=MY_S3_INTEGRATION
